PORT=4000
CLIENT_URL=http://localhost:3068
MONGO_URL=mongodb://localhost:27017/inventory-rental
JWT_ACCESS_SECRET=local-access-secret
JWT_REFRESH_SECRET=local-refresh-secret
ADMIN_EMAILS=admin@gorodaivesi.local

# Внешний URL API (для построения ссылок на локально сохранённые файлы в fallback-режиме)
PUBLIC_API_URL=http://localhost:4000

# Yandex Object Storage (S3-совместимое). Если не заданы все ключи — fallback на uploads/.
YANDEX_S3_ENDPOINT=https://storage.yandexcloud.net
YANDEX_S3_REGION=ru-central1
YANDEX_S3_BUCKET=your-bucket-name
YANDEX_S3_ACCESS_KEY=your-access-key
YANDEX_S3_SECRET_KEY=your-secret-key

# DaData (верификация ИНН -> данные компании)
DADATA_TOKEN=your-dadata-token

# Агент (ИП-владелец платформы) — реквизиты для агентского договора
AGENT_NAME=ИП Иванов Иван Иванович
AGENT_INN=000000000000
AGENT_OGRN=000000000000000
AGENT_ADDRESS=г. Москва, ул. Примерная, д. 1
AGENT_PHONE=+7 000 000-00-00
# Процент агентской комиссии (резерв под эквайринг, по умолчанию 0)
AGENT_COMMISSION_PERCENT=0
